APP_ENV=development
STORAGE_BACKEND=mongo
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=nihon_line_bot
MONGO_COLLECTION=captured_lodging_links
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_REPLY_ON_CAPTURE=true
COLLECTOR_OUTPUT_PATH=data/captured_lodging_links.jsonl
SUPPORTED_DOMAINS=booking.com,agoda.com
LINE_WELCOME_MESSAGE=已加入群組。之後只要貼 Booking 或 Agoda 的住宿連結，我就會先幫你收下來。
REPLY_CAPTURE_TEMPLATE=已收到 {count} 筆住宿連結，先幫你記下來了。
